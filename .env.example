# ── LLM Providers ─────────────────────────────────────────────────────────────
# Primary provider: claude | openai | groq  (default: claude)
LLM_PROVIDER=claude

ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key          # fallback when Claude unavailable
GROQ_API_KEY=your_groq_api_key              # secondary fallback (Llama 3.3-70B)
OLLAMA_HOST=http://localhost:11434          # local fallback (no key needed)

# ── Multi-Agent Pipeline Settings ─────────────────────────────────────────────
# Minimum LLM confidence score (0-1) before requiring human approval
MIN_CONFIDENCE_THRESHOLD=0.6
# Risk levels that auto-execute without human approval: low,medium
AUTO_EXECUTE_RISK_LEVELS=low,medium

# ── Continuous Monitoring Loop ─────────────────────────────────────────────────
# Set to true to enable background anomaly detection
ENABLE_MONITOR_LOOP=false
# How often to poll for anomalies (seconds)
MONITOR_INTERVAL_SECONDS=60
# Set to true to auto-remediate anomalies detected by the monitor (alert-only by default)
AUTO_REMEDIATE_ON_MONITOR=false

# ── Slack ──────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=your_slack_bot_token
SLACK_CHANNEL=#incidents

# ── Jira ───────────────────────────────────────────────────────────────────────
JIRA_URL=https://your-domain.atlassian.net
JIRA_USER=you@yourcompany.com
JIRA_TOKEN=your_jira_api_token
JIRA_PROJECT=DEVOPS

# ── OpsGenie ───────────────────────────────────────────────────────────────────
OPSGENIE_API_KEY=your_opsgenie_api_key

# ── GitHub ─────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=owner/repo

# ── AWS ────────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# ── Grafana ────────────────────────────────────────────────────────────────────
GRAFANA_URL=http://localhost:3000
GRAFANA_TOKEN=your_grafana_service_account_token

# ── GitLab ─────────────────────────────────────────────────────────────────────
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your_gitlab_personal_access_token
GITLAB_PROJECT=namespace/project

# ── Kubernetes ─────────────────────────────────────────────────────────────────
# Set to "true" when running inside a K8s pod (uses in-cluster config)
K8S_IN_CLUSTER=false
# Path to kubeconfig file (leave blank to use default ~/.kube/config)
# KUBECONFIG=/path/to/kubeconfig

# ── JWT Authentication (REQUIRED in production) ────────────────────────────────
JWT_SECRET_KEY=      # generate with: openssl rand -hex 32
JWT_EXPIRE_MINS=480  # 8 hours
AUTH_ENABLED=true    # set to false only for local development
ENVIRONMENT=production

# ── Security / RBAC ────────────────────────────────────────────────────────────
# Path to JSON file with user→role mappings: {"alice": "developer", "bob": "viewer"}
# RBAC_CONFIG_PATH=/path/to/roles.json

# ── Server ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# HOST=127.0.0.1
# PORT=8000

# ── SSO / OAuth2 (Google or GitHub) ────────────────────────────────────────
# SSO_PROVIDER=google          # or: github
# SSO_CLIENT_ID=your-client-id
# SSO_CLIENT_SECRET=your-client-secret
# SSO_REDIRECT_URI=https://your-domain.com/auth/sso/callback
# SSO_DEFAULT_ROLE=viewer      # role assigned to new SSO users

# ── JWT Key Rotation ────────────────────────────────────────────────────────
# To rotate: set JWT_SECRET_KEY to the NEW key and JWT_SECRET_KEY_OLD to the
# old key. Tokens signed with the old key are still accepted until they expire.
# After JWT_EXPIRE_MINS, remove JWT_SECRET_KEY_OLD.
# JWT_SECRET_KEY_OLD=

# ── Redis HA (Sentinel) ─────────────────────────────────────────────────────
# For production HA — use Sentinel instead of a single Redis node
# REDIS_SENTINEL_HOSTS=sentinel1:26379,sentinel2:26379,sentinel3:26379
# REDIS_SENTINEL_MASTER=mymaster

# ── ChromaDB Backup ─────────────────────────────────────────────────────────
# CHROMA_DB_PATH=./chroma_db
# CHROMA_BACKUP_DIR=./chroma_backups
