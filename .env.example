# Slack
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#general

# Jira
JIRA_URL=https://your-domain.atlassian.net
JIRA_USER=you@yourcompany.com
JIRA_TOKEN=your-jira-api-token
JIRA_PROJECT=DEVOPS

# Opsgenie
OPSGENIE_API_KEY=your_opsgenie_api_key

# GitHub
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=owner/repo

# AWS
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID= (if not using IAM)
# AWS_SECRET_ACCESS_KEY=

# Claude / LLM (if implemented)
# CLAUDE_API_KEY=

# Kubernetes
# Set to "true" when running inside a K8s pod (uses in-cluster config)
K8S_IN_CLUSTER=false
# Path to kubeconfig file (leave blank to use default ~/.kube/config)
# KUBECONFIG=/path/to/kubeconfig

# RBAC config file (optional — JSON mapping users to roles)
# RBAC_CONFIG_PATH=/path/to/roles.json

# Optional: host and port for uvicorn
# HOST=127.0.0.1
# PORT=8000
